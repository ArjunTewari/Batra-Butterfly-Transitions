{
  "version": 2,
  "buildCommand": "pnpm run build:api && pnpm run build:frontend",
  "outputDirectory": "artifacts/batra-butterfly/dist/public",
  "functions": {
    "api/index.js": {
      "memory": 1024,
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/:path*", "destination": "/api/index" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
